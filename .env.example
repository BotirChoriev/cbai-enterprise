# CBAI — Supabase configuration (Real Supabase Authentication + Cloud Persistence mission)
#
# Copy this file to `.env.local` and fill in real values from your Supabase project settings
# (Project Settings -> API) to activate Cloud Mode. Without these two variables set, CBAI runs
# entirely in Local Mode — real local-device accounts, browser-storage persistence — and says so
# honestly everywhere in the UI. Nothing here is required to run or build the app.
#
# Never commit `.env.local` (already gitignored via the `.env*` rule in .gitignore).

# The Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
# Public by design — safe to ship in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=

# The Project's anon/public API key (Project Settings -> API -> Project API keys -> anon public).
# Public by design — Row Level Security policies (see supabase/migrations/) are what actually
# protect data, not secrecy of this key. Safe to ship in the browser bundle.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# BUILD-039 live verification (test environment only — never commit real passwords)
# CBAI_TEST_USER_A_EMAIL=
# CBAI_TEST_USER_A_PASSWORD=
# CBAI_TEST_USER_B_EMAIL=
# CBAI_TEST_USER_B_PASSWORD=
# CBAI_TEST_USER_C_EMAIL=
# CBAI_TEST_USER_C_PASSWORD=
# CBAI_TEST_BASE_URL=http://127.0.0.1:3000

# Public URL of the Voice Operator session broker (Cloudflare Pages Function or Supabase Edge Function).
# Does NOT contain an OpenAI API key — only the HTTPS endpoint that returns ephemeral Realtime credentials.
# When unset, Voice Operator runs in browser-fallback mode and labels live conversation as BACKEND REQUIRED.
NEXT_PUBLIC_VOICE_BROKER_URL=
 This app is a Next.js static export
# (output: "export" in next.config.ts) with no server runtime, no API routes, and no middleware —
# there is nowhere in this architecture that could hold a service-role key privately. A
# service-role key must NEVER be added to this file or any NEXT_PUBLIC_* variable: it would ship
# to every browser and bypass Row Level Security entirely. All schema changes, backfills, or
# admin operations must be run from the Supabase SQL editor or CLI, never from application code.
